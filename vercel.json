{
  "buildCommand": "npm install && cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/payments/create-order", "destination": "/api/payments-create" },
    { "source": "/api/payments/capture-order", "destination": "/api/payments-capture" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
